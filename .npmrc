# The SWIP packages (@sloopworks/swip-*) publish to GitHub Packages, not npmjs
# (ADR 0058; the Gradle side already does the same for swip-core — see
# apps/settings.gradle.kts). NO TOKEN LIVES HERE: npm expands NODE_AUTH_TOKEN from the
# environment. CI passes the SLOOPWORKS_PACKAGES_TOKEN repo secret (read:packages);
# locally, `export NODE_AUTH_TOKEN=$(gh auth token)`.
@sloopworks:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
